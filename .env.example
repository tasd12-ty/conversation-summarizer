# ============================================================
# LLM 后端模式：cloud（云端 API）或 vllm（本地 vLLM 部署）
# ============================================================
LLM_API_MODE=cloud

# ============================================================
# 模式一：云端 API 配置（LLM_API_MODE=cloud）
# ============================================================
LLM_API_BASE=
LLM_MODEL=
LLM_ACCESS_KEY=your-access-key-here
LLM_QUOTA_ID=
LLM_USER_ID=
LLM_TAG=conversation_summarizer

# ============================================================
# 模式二：本地 vLLM 部署配置（LLM_API_MODE=vllm）
# 取消下方注释并填入 GPU 服务器地址即可切换
# ============================================================
# LLM_API_MODE=vllm
# LLM_API_BASE=http://<GPU_SERVER_IP>:8000/v1/chat/completions
# LLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# LLM_ACCESS_KEY=not-needed

# 服务配置
HOST=0.0.0.0
PORT=8000
